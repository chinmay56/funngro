# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://funngro.com

# Analytics
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Contact Form (Optional - if using email service)
EMAIL_SERVICE_API_KEY=your-api-key
CONTACT_EMAIL=business@funngro.com

# Database (Optional - if adding backend)
DATABASE_URL=your-database-url

# App Store Links
NEXT_PUBLIC_IOS_APP_URL=https://apps.apple.com/your-app
NEXT_PUBLIC_ANDROID_APP_URL=https://play.google.com/store/apps/your-app
